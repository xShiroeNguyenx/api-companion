{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "API Companion",
  "version": "0.4.4",
  "identifier": "com.apicompanion.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "API Companion",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xShiroeNguyenx/api-companion/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0NkIxQjU2QzEyQjFGQzIKUldUQ0h5dkJWaHRyWkltYlRiWVAydStEZnBxcStIY2hXY0h1VXdIQy9JOTcyZEl5ZDhvdTJJSUUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
